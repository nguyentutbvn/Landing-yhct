              "id": "check-email",
              "leftValue": "={{ $json.email }}",
              "rightValue": "N/A",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            },
            {
              "id": "check-email-empty",
              "leftValue": "={{ $json.email }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-email-1",
      "name": "Có email?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 620]
