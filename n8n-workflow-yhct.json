    {
      "parameters": {
        "fromEmail": "tuyensinh@truong.edu.vn",
        "toEmail": "={{ $json.email }}",
        "subject": "{{ $json.fullname }} ơi - 3 điều bạn chưa biết về ngành Y Học Cổ Truyền",
        "emailType": "html",
        "html": "=<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n  <div style=\"padding: 30px; background: #fff;\">\n    <h2 style=\"color: #1a5c2e;\">🌿 3 điều thú vị về ngành YHCT</h2>\n    <p>Chào <strong>{{ $json.fullname }}</strong>,</p>\n    <p>Hy vọng bạn đã tìm hiểu thêm về ngành Y Học Cổ Truyền. Đây là 3 điều có thể bạn chưa biết:</p>\n    <ol>\n      <li><strong>Thu nhập cao:</strong> Bác sĩ YHCT mở phòng khám riêng có thể đạt 30-50 triệu/tháng</li>\n      <li><strong>Nhu cầu tăng:</strong> Xu hướng trị liệu tự nhiên đang bùng nổ toàn cầu</li>\n      <li><strong>Đa dạng nghề:</strong> Từ bệnh viện, spa cao cấp đến nghiên cứu dược liệu</li>\n    </ol>\n    <div style=\"text-align: center; margin: 30px 0;\">\n      <a href=\"#\" style=\"display: inline-block; background: #c8a951; color: #1a1a1a; padding: 14px 32px; border-radius: 30px; text-decoration: none; font-weight: bold;\">ĐĂNG KÝ NGAY - CÒN 200 SUẤT HỌC BỔNG</a>\n    </div>\n    <p style=\"color: #888;\">Có thắc mắc? Gọi ngay <strong>1900 1234</strong></p>\n  </div>\n</div>",
        "options": {}
      },
      "id": "email-nurture-1",
      "name": "Email nurture (3 ngày sau)",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [1160, 700]
    }
