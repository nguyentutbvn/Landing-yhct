      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "text": "=📊 **BÁO CÁO TUYỂN SINH HÀNG NGÀY**\n━━━━━━━━━━━━━━━━━━\n\n📅 Ngày: {{ $now.format('dd/MM/yyyy') }}\n📝 Tổng lead mới: {{ $input.all().length }}\n🔥 Lead nóng: {{ $input.all().filter(i => i.json.lead_score >= 8).length }}\n🟡 Lead ấm: {{ $input.all().filter(i => i.json.lead_score >= 5 && i.json.lead_score < 8).length }}\n🔵 Lead lạnh: {{ $input.all().filter(i => i.json.lead_score < 5).length }}\n\n📌 Top nguồn:\n{{ $input.all().map(i => i.json.utm_source || i.json.source).filter((v,i,a) => a.indexOf(v) === i).join(', ') }}\n\n━━━━━━━━━━━━━━━━━━\n💡 Nhớ follow-up lead nóng trong ngày!",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
