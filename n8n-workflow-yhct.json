{
  "name": "Tuyển Sinh YHCT - Lead Processing",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "tuyen-sinh-yhct",
        "responseMode": "onReceived",
        "responseData": "allEntries",
        "options": {
          "responseCode": 200,
          "responseData": "{\"status\":\"ok\",\"message\":\"Đã nhận đăng ký\"}"
        }
      },
      "id": "webhook-1",
      "name": "Webhook - Nhận Form",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "set-fullname",
              "name": "fullname",
              "value": "={{ $json.body.fullname }}",
              "type": "string"
            },
            {
              "id": "set-phone",
              "name": "phone",
              "value": "={{ $json.body.phone }}",
              "type": "string"
            },
            {
              "id": "set-email",
              "name": "email",
              "value": "={{ $json.body.email || 'N/A' }}",
              "type": "string"
            },
            {
              "id": "set-province",
              "name": "province",
              "value": "={{ $json.body.province || 'N/A' }}",
              "type": "string"
            },
            {
              "id": "set-education",
              "name": "education",
              "value": "={{ $json.body.education || 'N/A' }}",
              "type": "string"
            },
            {
              "id": "set-interest",
              "name": "interest",
              "value": "={{ $json.body.interest || 'N/A' }}",
              "type": "string"
            },
            {
              "id": "set-source",
              "name": "source",
              "value": "={{ $json.body.source || 'direct' }}",
              "type": "string"
            },
            {
              "id": "set-utm-source",
              "name": "utm_source",
              "value": "={{ $json.body.utm_source || '' }}",
              "type": "string"
            },
            {
              "id": "set-utm-medium",
              "name": "utm_medium",
              "value": "={{ $json.body.utm_medium || '' }}",
              "type": "string"
            },
            {
              "id": "set-utm-campaign",
              "name": "utm_campaign",
              "value": "={{ $json.body.utm_campaign || '' }}",
              "type": "string"
            },
            {
              "id": "set-lead-score",
              "name": "lead_score",
              "value": "={{ $json.body.lead_score || 5 }}",
              "type": "number"
            },
            {
              "id": "set-timestamp",
              "name": "timestamp",
              "value": "={{ $json.body.timestamp || $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "set-lead-type",
              "name": "lead_type",
              "value": "={{ $json.body.lead_score >= 8 ? 'HOT' : $json.body.lead_score >= 5 ? 'WARM' : 'COLD' }}",
              "type": "string"
            },
            {
              "id": "set-status",
              "name": "status",
              "value": "Mới",
              "type": "string"
            }
          ]
        }
      },
      "id": "set-data-1",
      "name": "Chuẩn hóa dữ liệu",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "documentId": {
          "__rl": true,
          "mode": "url",
          "value": "https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "Sheet1"
        },
        "columns": {
          "mappingMode": "autoMapInputData",
          "value": {}
        },
        "options": {}
      },
      "id": "gsheet-1",
      "name": "Lưu Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [700, 160]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-hot",
              "leftValue": "={{ $json.lead_score }}",
              "rightValue": 8,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-hot-1",
      "name": "Lead nóng?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [700, 440]
    },
    {
      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "text": "=🔥 **LEAD NÓNG - CẦN GỌI NGAY!**\n\n👤 **{{ $json.fullname }}**\n📞 {{ $json.phone }}\n📧 {{ $json.email }}\n📍 {{ $json.province }}\n🎓 {{ $json.education }}\n💊 Quan tâm: {{ $json.interest }}\n📊 Điểm lead: {{ $json.lead_score }}/10\n🔗 Nguồn: {{ $json.utm_source || $json.source }}\n⏰ {{ $json.timestamp }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "telegram-hot-1",
      "name": "Telegram - Lead nóng",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [940, 340]
    },
    {
      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "text": "=📋 **Lead mới đăng ký**\n\n👤 {{ $json.fullname }}\n📞 {{ $json.phone }}\n📧 {{ $json.email }}\n💊 {{ $json.interest }}\n📊 Điểm: {{ $json.lead_score }}/10\n🏷️ Loại: {{ $json.lead_type }}\n🔗 {{ $json.utm_source || $json.source }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "telegram-warm-1",
      "name": "Telegram - Lead ấm/lạnh",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [940, 540]
    },
    {
      "parameters": {
        "fromEmail": "tuyensinh@truong.edu.vn",
        "toEmail": "={{ $json.email }}",
        "subject": "Chào {{ $json.fullname }} - Cảm ơn bạn đã quan tâm ngành Y Học Cổ Truyền!",
        "emailType": "html",
        "html": "=<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n  <div style=\"background: #1a5c2e; color: white; padding: 30px; text-align: center; border-radius: 12px 12px 0 0;\">\n    <h1 style=\"margin: 0;\">🌿 Y Học Cổ Truyền</h1>\n    <p style=\"margin: 8px 0 0; opacity: 0.9;\">Cảm ơn bạn đã đăng ký!</p>\n  </div>\n  <div style=\"padding: 30px; background: #fff; border: 1px solid #e5e5e5;\">\n    <p>Xin chào <strong>{{ $json.fullname }}</strong>,</p>\n    <p>Cảm ơn bạn đã quan tâm đến ngành <strong>Y Học Cổ Truyền</strong>. Chúng tôi đã nhận được thông tin đăng ký của bạn.</p>\n    <p>Đội ngũ tư vấn sẽ liên hệ bạn qua số điện thoại <strong>{{ $json.phone }}</strong> trong vòng <strong>24 giờ</strong>.</p>\n    <hr style=\"margin: 20px 0; border: none; border-top: 1px solid #eee;\">\n    <h3>📚 Trong thời gian chờ, bạn có thể:</h3>\n    <ul>\n      <li>Tìm hiểu chương trình đào tạo chi tiết</li>\n      <li>Xem video giới thiệu ngành</li>\n      <li>Đọc chia sẻ từ cựu sinh viên</li>\n    </ul>\n    <div style=\"text-align: center; margin: 30px 0;\">\n      <a href=\"#\" style=\"display: inline-block; background: #c8a951; color: #1a1a1a; padding: 14px 32px; border-radius: 30px; text-decoration: none; font-weight: bold;\">XEM CHƯƠNG TRÌNH ĐÀO TẠO</a>\n    </div>\n    <p style=\"color: #888; font-size: 13px;\">Nếu cần hỗ trợ gấp, gọi Hotline: <strong>1900 1234</strong></p>\n  </div>\n  <div style=\"text-align: center; padding: 20px; color: #aaa; font-size: 12px;\">\n    © 2026 Khoa Y Học Cổ Truyền<br>\n    <a href=\"#\" style=\"color: #aaa;\">Hủy đăng ký nhận email</a>\n  </div>\n</div>",
        "options": {}
      },
      "id": "email-confirm-1",
      "name": "Email xác nhận",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [700, 620]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * *"
