        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "Sheet1"
        },
        "filters": {
          "conditions": [
            {
              "id": "filter-today",
              "leftValue": "={{ $json.timestamp }}",
              "rightValue": "={{ $now.minus({days: 1}).toISO() }}",
              "operator": {
                "type": "string",
                "operation": "gte"
              }
            }
          ]
        },
        "options": {}
      },
